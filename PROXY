const express = require("express");

const app = express();

app.get("/", (req, res) => {
  res.send("Reverse proxy working 🔥");
});

app.get("/api", (req, res) => {
  res.json({
    status: "ok",
    ip: req.headers["x-forwarded-for"] || req.socket.remoteAddress
  });
});

const PORT = 3000;

app.listen(PORT, () => {
  console.log(`App running on ${PORT}`);
});
